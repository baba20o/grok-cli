{
  "name": "grok-agent",
  "version": "0.6.0",
  "description": "A coding assistant CLI powered by xAI's Grok models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "grok-agent": "./bin/grok-cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-tests/tests/*.test.js",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "grok",
    "xai",
    "cli",
    "coding-assistant",
    "agent",
    "ai",
    "llm",
    "developer-tools",
    "code-generation",
    "function-calling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/baba20o/grok-cli.git"
  },
  "homepage": "https://github.com/baba20o/grok-cli#readme",
  "bugs": {
    "url": "https://github.com/baba20o/grok-cli/issues"
  },
  "author": "baba20o",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "fast-glob": "^3.3.3",
    "openai": "^4.86.0",
    "ora": "^8.2.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
